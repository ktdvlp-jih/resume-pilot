# Java / Gradle
.gradle/
**/build/
**/bin/
**/out/
*.class
!**/gradle/wrapper/gradle-wrapper.jar

# Node (resume-web, resume-admin)
node_modules/
dist/
dist-ssr/
*.tsbuildinfo
.npm
.eslintcache

# Python (resume-ai, prompt-service, rag-service)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
*.egg

# ---------------------------------------------------------------------------
# Environment & secrets — NEVER commit (API keys, DB passwords, JWT, LLM keys)
# Copy from *.env.example and fill in locally.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.production.example

resume-web/.env
resume-web/.env.local
resume-web/.env.*.local

resume-admin/.env
resume-admin/.env.local
resume-admin/.env.*.local

resume-ai/.env
resume-ai/.env.local
resume-ai/.env.*.local

prompt-service/.env
prompt-service/.env.local
prompt-service/.env.*.local

rag-service/.env
rag-service/.env.local
rag-service/.env.*.local

# Spring Boot local overrides (often contain real DB/JWT values)
**/application-local.yml
**/application-local.yaml
**/application-local.properties

# Docker Compose local overrides (ports, secrets)
compose.override.yaml
compose.override.yml
docker-compose.override.yml
docker-compose.override.yaml

# Cloudflare Tunnel credentials
.cloudflared/
*.pem

# Ad-hoc secret files
secrets/
*.secret
*credentials*.json
*.key

# IDE / OS
.idea/
.vscode/
*.iml
*.swp
*.swo
.DS_Store
Thumbs.db

# Local logs / runtime
*.log
logs/
.deploy-status.json
.deploy-last.log
.docker-deploy-ci/
docker-data/

# SpecStory — 자주 바뀌는 메타만 제외 (history/*.md 는 Git 동기화)
.specstory/statistics.json

# 로컬 API 스모크 테스트 payload (Cursor 임시 생성)
tmp-smoke-eval.json
tmp-*.json

# Cursor indexing (워크스페이스별)
.cursorindexingignore

# ---------------------------------------------------------------------------
# Agent Skills (npx skills)
# - 외부(Vercel 등) Skill 대부분은 "다운로드/링크"만을 위해 로컬에서 생성
# - 프로젝트 커스텀 Skill만 커밋 소스 오브 트루스(source of truth)로 남김
# ---------------------------------------------------------------------------

# Vercel/외부로 받은 Skill은 기본적으로 커밋하지 않음
.agents/skills/**
!.agents/skills/api-smoke/
!.agents/skills/api-smoke/SKILL.md
!.agents/skills/deploy-smoke/
!.agents/skills/deploy-smoke/SKILL.md

# skills CLI가 생성하는 잠금/메타(재현은 install script/명령으로)
skills-lock.json

# Cursor/Claude 에이전트는 위 .agents를 기반으로 링크/복사되며,
# 여기의 skills 폴더는 대개 생성물(로컬 링크)이라 커밋하지 않음
.cursor/skills/
.claude/skills/
