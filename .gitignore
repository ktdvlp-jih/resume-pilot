# Java / Gradle
.gradle/
**/build/
**/bin/
**/out/
*.class
!**/gradle/wrapper/gradle-wrapper.jar

# Node (resume-web, resume-admin)
node_modules/
dist/
dist-ssr/
*.tsbuildinfo
.npm
.eslintcache

# Python (resume-ai, prompt-service, rag-service)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
*.egg

# ---------------------------------------------------------------------------
# Environment & secrets — NEVER commit (API keys, DB passwords, JWT, LLM keys)
# Copy from *.env.example and fill in locally.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.production.example

resume-web/.env
resume-web/.env.local
resume-web/.env.*.local

resume-admin/.env
resume-admin/.env.local
resume-admin/.env.*.local

resume-ai/.env
resume-ai/.env.local
resume-ai/.env.*.local

prompt-service/.env
prompt-service/.env.local
prompt-service/.env.*.local

rag-service/.env
rag-service/.env.local
rag-service/.env.*.local

# Spring Boot local overrides (often contain real DB/JWT values)
**/application-local.yml
**/application-local.yaml
**/application-local.properties

# Docker Compose local overrides (ports, secrets)
compose.override.yaml
compose.override.yml
docker-compose.override.yml
docker-compose.override.yaml

# Cloudflare Tunnel credentials
.cloudflared/
*.pem

# Ad-hoc secret files
secrets/
*.secret
*credentials*.json
*.key

# IDE / OS
.idea/
.vscode/
*.iml
*.swp
*.swo
.DS_Store
Thumbs.db

# Local logs / runtime
*.log
logs/
.deploy-status.json
.deploy-last.log
.docker-deploy-ci/
docker-data/

# SpecStory — 로컬 전용 (대화에 API 키 등이 섞일 수 있어 Git 제외)
.specstory/

# 로컬 API 스모크 테스트 payload (Cursor 임시 생성)
tmp-smoke-eval.json
tmp-*.json

# Cursor indexing (워크스페이스별)
.cursorindexingignore

# ---------------------------------------------------------------------------
# Agent Skills (npx skills)
# - 외부(Vercel 등) Skill은 각 PC에서 npx skills add로 설치·링크 (커밋 안 함)
# - 커스텀 Skill(api-smoke·deploy-smoke)은 .claude/skills·.cursor/skills에 직접 커밋
#   → 상세: docs/AI-Agent-스킬-정책.md
# ---------------------------------------------------------------------------

# npx skills 소스 저장소(생성물) — 전체 무시
.agents/skills/**

# skills CLI가 생성하는 잠금/메타(재현은 정책 문서의 명령으로)
skills-lock.json

# 에이전트 스킬 폴더: npx가 만든 링크(Junction)는 무시, 커스텀 스킬만 예외로 커밋
.cursor/skills/*
!.cursor/skills/api-smoke/
!.cursor/skills/deploy-smoke/
.claude/skills/*
!.claude/skills/api-smoke/
!.claude/skills/deploy-smoke/
