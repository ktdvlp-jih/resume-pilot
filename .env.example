# =============================================================================
# ResumePilot — LOCAL DEVELOPMENT (터미널 실행용)
#   cp .env.example .env
#
# Docker compose(배포)는 .env.production.example 을 사용합니다.
# 실행 가이드: docs/RUNNING.md
# =============================================================================

COMPOSE_PROJECT_NAME=resume-pilot

# ===== PostgreSQL (docker run 또는 로컬 PG) =====
POSTGRES_DB=resumepilot
POSTGRES_USER=resumepilot
POSTGRES_PASSWORD=resumepilot

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/resumepilot
SPRING_DATASOURCE_USERNAME=resumepilot
SPRING_DATASOURCE_PASSWORD=resumepilot
DATABASE_URL=postgresql://resumepilot:resumepilot@localhost:5432/resumepilot

# ===== Spring API (gradlew bootRun) =====
JWT_SECRET=change-me-to-a-secure-random-string-at-least-256-bits
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
RESUME_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173
INTERNAL_API_TOKEN=change-me-internal-token
LLM_ENCRYPTION_KEY=change-me-32-byte-or-longer-secret

# ===== AI 서비스 (uvicorn, localhost) =====
RESUME_AI_SERVICE_URL=http://localhost:8000
RESUME_AI_URL=http://localhost:8000
RESUME_API_URL=http://localhost:8080
PROMPT_SERVICE_URL=http://localhost:8001
RAG_SERVICE_URL=http://localhost:8002

# ===== RAG (pgvector 차원 — DB 스키마와 일치) =====
EMBEDDING_DIMENSION=1536

# ===== LLM API 키 — Admin /admin/llm-settings 에서 관리 (아래는 마이그레이션 폴백) =====
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# EMBEDDING_MODEL=text-embedding-3-small

# ===== Vite (npm run dev) =====
VITE_API_URL=http://localhost:8080
# VITE_SENTRY_DSN=          # optional — frontend error tracking (web + admin)

# ===== Deploy (로컬 PC → 서버, Git 커밋 금지) =====
# DEPLOY_HOST=jeon@your-lan-host
# LAN_HOST=your-lan-host
# APP_PORT=9180
